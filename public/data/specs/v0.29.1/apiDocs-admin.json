        ],
        "summary": "시스템 미션 수정",
        "description": "시스템 미션을 수정합니다. OPEN 상태인 미션만 수정할 수 있습니다.",
        "operationId": "updateSystemMission-FO2Zqu0",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "미션 ID",
