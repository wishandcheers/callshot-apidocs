      }
    },
    "/api/admin/external/events/refresh": {
      "post": {
        "tags": [
          "Admin 외부 이벤트"
        ],
        "summary": "외부 이벤트 수동 동기화 (비동기)",
        "description": "외부 API 전량 동기화를 백그라운드로 시작하고 즉시 202를 반환한다(전량 fetch가 수십 초 걸려 동기 호출은 504가 나기 때문). 완료까지 ~1분 뒤 목록을 다시 조회하면 반영된다. 이미 진행 중이면 새로 시작하지 않고 accepted\u003dfalse로 응답한다.",
        "operationId": "refresh",
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "description": "데이터 소스 (기본 CULTURE_EVENT)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "CULTURE_EVENT"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "동기화 시작됨(또는 이미 진행 중)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseExternalEventRefreshResponse"
                }
              }
            }
          }
        }
      }
    },
