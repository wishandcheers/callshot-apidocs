    "/api/admin/external/events": {
      "get": {
        "tags": [
          "Admin 외부 이벤트"
        ],
        "summary": "외부 이벤트 목록 조회",
        "description": "공공데이터포털 이벤트를 정규화해 조회한다. 좌표 없는 항목은 응답에서 제외된다.",
        "operationId": "getExternalEvents",
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "description": "데이터 소스 (기본 CULTURE_EVENT)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "CULTURE_EVENT"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "행사명/내용 부분일치",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sido",
            "in": "query",
            "description": "시도명 (예: 서울특별시)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sigungu",
            "in": "query",
            "description": "시군구명 (예: 강남구)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dateFrom",
            "in": "query",
            "description": "행사 기간 필터 시작 (yyyy-MM-dd)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "행사 기간 필터 종료 (yyyy-MM-dd)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "페이지 (1-base, 기본 1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "페이지 크기 (기본 20, 최대 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "조회 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseExternalEventPageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/photos/seed/{source}": {
      "delete": {
        "tags": [
          "Admin 사진 시딩"
        ],
        "summary": "소스별 시드 일괄 삭제",
        "description": "특정 소스로 적재된 모든 시드 사진과 연관 데이터(engagement/댓글 등)를 일괄 삭제한다.",
        "operationId": "deleteBySource",
        "parameters": [
          {
            "name": "source",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "WIKIMEDIA",
                "FLICKR",
                "INATURALIST",
                "MAPILLARY"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSeedDeleteResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ModifyUserProfileRequest": {
        "type": "object",
        "description": "프로필 수정 요청 (관리자)",
        "properties": {
          "nickname": {
            "type": "string",
            "description": "닉네임",
            "example": "callshot_user"
          },
          "avatarUrl": {
            "type": "string",
            "description": "아바타 이미지 URL"
          },
          "gender": {
            "type": "string",
            "description": "성별",
            "enum": [
              "MALE",
              "FEMALE",
              "UNKNOWN"
            ],
            "example": "MALE"
          },
          "birthdate": {
            "type": "string",
            "format": "date",
            "description": "생년월일",
            "example": "1995-03-15"
          },
          "bio": {
            "type": "string",
            "description": "자기소개"
          }
        },
        "required": [
          "nickname"
        ]
      },
      "BaseResponseUnit": {
        "type": "object",
        "description": "API 공통 응답 래퍼",
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader",
            "description": "응답 헤더 (성공 여부, 상태 코드)"
          },
          "body": {
            "description": "응답 본문"
          }
        },
        "required": [
          "header"
        ]
      },
      "ResponseHeader": {
        "type": "object",
        "description": "응답 헤더",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "요청 성공 여부",
            "example": true
          },
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP 상태 코드",
            "example": 200
          },
          "errorMessage": {
            "type": "string",
            "description": "에러 메시지 (실패 시)",
            "example": "잘못된 요청입니다"
          }
        },
        "required": [
          "code",
          "success"
        ]
      },
      "SeedImportRequest": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "WIKIMEDIA",
              "FLICKR",
              "INATURALIST",
              "MAPILLARY"
            ]
          },
          "minLat": {
            "type": "number",
            "format": "double"
          },
          "maxLat": {
            "type": "number",
            "format": "double"
          },
          "minLng": {
            "type": "number",
            "format": "double"
          },
          "maxLng": {
            "type": "number",
            "format": "double"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          }
        },
        "required": [
          "limit",
          "maxLat",
          "maxLng",
          "minLat",
          "minLng",
          "source"
        ]
      },
      "BaseResponseSeedImportResponse": {
        "type": "object",
        "description": "API 공통 응답 래퍼",
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader",
            "description": "응답 헤더 (성공 여부, 상태 코드)"
          },
          "body": {
            "$ref": "#/components/schemas/SeedImportResponse",
            "description": "응답 본문"
          }
        },
        "required": [
          "header"
        ]
      },
      "SeedImportResponse": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "WIKIMEDIA",
              "FLICKR",
              "INATURALIST",
              "MAPILLARY"
            ]
          },
          "fetched": {
            "type": "integer",
            "format": "int32"
          },
          "imported": {
            "type": "integer",
            "format": "int32"
          },
          "skipped": {
            "type": "integer",
            "format": "int32"
          },
          "failed": {
            "type": "integer",
            "format": "int32"
          }
        },
        "required": [
          "failed",
          "fetched",
          "imported",
          "skipped",
          "source"
        ]
      },
      "CreateSystemMissionRequest": {
        "type": "object",
        "description": "시스템 미션 생성 정보",
        "properties": {
          "title": {
            "type": "string",
            "description": "미션 제목",
            "example": "경복궁 야경 촬영",
            "maxLength": 100,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "미션 설명",
            "example": "경복궁 야간 개장 시간에 촬영해주세요",
            "maxLength": 2000,
            "minLength": 0
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "위도",
            "example": 37.5796,
            "maximum": 90.0,
            "minimum": -90.0
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "경도",
            "example": 126.977,
            "maximum": 180.0,
            "minimum": -180.0
          },
          "altitude": {
            "type": "number",
            "format": "double",
