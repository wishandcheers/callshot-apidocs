{
  "openapi": "3.1.0",
  "info": {
    "title": "CallShot API",
    "description": "# API Guide\nThis is a Api alpha-server for CallShot App.\n\n## Common Rules\n- 인증이 필요한 API는 `Authorization: Bearer {id_token}` 헤더를 포함해야 합니다.\n\n## CDN Guide\n- CDN URL 형식: `https://{cdn_host}/{path}`\n    - cdn_host: `dev-cdn.call-shot.com`\n- Original URL path: `/origin/{file_path}`\n    - ex: https://dev-cdn.call-shot.com/origin/times_square.jpg\n- Thumbnail URL path: /thumb/{file_path}?w\u003d{size}\n    - Thumbnail URL의 경우 QueryString 없이 내려감\n    - size: 썸네일 크기\n    - ex: https://dev-cdn.call-shot.com/thumb/callshot/times_square.jpg?w\u003d200\n",
    "version": "0.13.0"
  },
  "servers": [
    {
      "url": "https://dev-api.call-shot.com",
      "description": "Development server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Admin",
      "description": "관리자 전용 API"
    },
    {
      "name": "Admin 미션",
      "description": "관리자 시스템 미션 관리 API"
    }
  ],
  "paths": {
    "/api/admin/users/{id}/profile": {
      "put": {
        "tags": [
          "Admin"
        ],
        "operationId": "modifyProfile",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModifyUserProfileRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseUnit"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/missions": {
      "get": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 목록 조회",
        "description": "모든 시스템 미션 목록을 조회합니다.",
        "operationId": "getSystemMissions",
        "responses": {
          "200": {
            "description": "조회 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSystemMissionsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 생성",
        "description": "새로운 시스템 미션을 생성합니다. source\u003dSYSTEM, requesterId\u003d시스템 사용자로 자동 설정됩니다.",
        "operationId": "createSystemMission",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSystemMissionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "생성 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSystemMissionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/missions/{missionId}/submissions/{submissionId}/review": {
      "post": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 제출 검토",
        "description": "시스템 미션에 대한 제출을 채택 또는 거절합니다.",
        "operationId": "reviewSubmission",
        "parameters": [
          {
            "name": "missionId",
            "in": "path",
            "description": "미션 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "submissionId",
            "in": "path",
            "description": "제출 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewSystemMissionSubmissionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "검토 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseUnit"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/missions/{id}/close": {
      "post": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 마감",
        "description": "시스템 미션을 마감 처리합니다. OPEN 상태인 미션만 마감할 수 있습니다.",
        "operationId": "closeMission",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "미션 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "마감 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseUnit"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/missions/{id}": {
      "get": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 상세 조회",
        "description": "시스템 미션의 상세 정보를 메타데이터와 함께 조회합니다.",
        "operationId": "getSystemMissionDetail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "미션 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "조회 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSystemMissionResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 취소",
        "description": "시스템 미션을 취소합니다. OPEN 상태인 미션만 취소할 수 있습니다.",
        "operationId": "cancelMission",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "미션 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "취소 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseUnit"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Admin 미션"
        ],
        "summary": "시스템 미션 수정",
        "description": "시스템 미션을 수정합니다. OPEN 상태인 미션만 수정할 수 있습니다.",
        "operationId": "updateSystemMission",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "미션 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSystemMissionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "수정 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseSystemMissionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "findAll",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0,
              "maximum": 9223372036854775807,
              "minimum": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 9223372036854775807,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseListUserDetailsResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/users/{id}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "findById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponseUserDetailsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ModifyUserProfileRequest": {
        "type": "object",
        "description": "프로필 수정 요청 (관리자)",
        "properties": {
          "nickname": {
            "type": "string",
            "description": "닉네임",
            "example": "callshot_user"
          },
          "avatarUrl": {
            "type": "string",
            "description": "아바타 이미지 URL"
          },
          "gender": {
            "type": "string",
            "description": "성별",
            "enum": [
              "MALE",
              "FEMALE",
              "UNKNOWN"
            ],
            "example": "MALE"
          },
          "birthdate": {
            "type": "string",
            "format": "date",
            "description": "생년월일",
            "example": "1995-03-15"
          },
          "bio": {
            "type": "string",
            "description": "자기소개"
          }
        },
        "required": [
          "nickname"
        ]
      },
      "BaseResponseUnit": {
        "type": "object",
        "description": "API 공통 응답 래퍼",
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader",
            "description": "응답 헤더 (성공 여부, 상태 코드)"
          },
          "body": {
            "description": "응답 본문"
          }
        },
        "required": [
          "header"
        ]
      },
      "ResponseHeader": {
        "type": "object",
        "description": "응답 헤더",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "요청 성공 여부",
            "example": true
          },
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP 상태 코드",
            "example": 200
          },
          "errorMessage": {
            "type": "string",
            "description": "에러 메시지 (실패 시)",
            "example": "잘못된 요청입니다"
          }
        },
        "required": [
          "code",
          "success"
        ]
      },
      "CreateSystemMissionRequest": {
        "type": "object",
        "description": "시스템 미션 생성 정보",
        "properties": {
          "title": {
            "type": "string",
            "description": "미션 제목",
            "example": "경복궁 야경 촬영",
            "maxLength": 100,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "미션 설명",
            "example": "경복궁 야간 개장 시간에 촬영해주세요",
            "maxLength": 2000,
            "minLength": 0
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "description": "위도",
            "example": 37.5796,
            "maximum": 90.0,
            "minimum": -90.0
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "description": "경도",
            "example": 126.977,
            "maximum": 180.0,
            "minimum": -180.0
          },
          "altitude": {
            "type": "number",
            "format": "double",
            "description": "고도 (미터)",
            "example": 35.0
          },
          "direction": {
            "type": "number",
            "format": "double",
            "description": "촬영 방향 (0-360도)",
            "example": 0.0,
            "maximum": 359.99,
            "minimum": 0.0
          },
          "address": {
            "type": "string",
            "description": "주소",
            "example": "서울특별시 종로구 사직로 161",
            "maxLength": 200,
            "minLength": 0
          },
          "expiresAtEpochMilli": {
            "type": "integer",
            "format": "int64",
            "description": "마감일시 (Epoch milliseconds)",
            "example": 1735689600000
          },
          "maxSubmissions": {
            "type": "integer",
            "format": "int32",
            "description": "최대 제출 수",
            "example": 50,
            "maximum": 100,
            "minimum": 1
          },
          "rewardDescription": {
            "type": "string",
            "description": "보상 설명",
            "example": "스타벅스 기프티카드 5,000원",
            "maxLength": 500,
            "minLength": 0
          },
          "priority": {
            "type": "integer",
            "format": "int32",
            "description": "우선순위 (높을수록 상위 노출)",
            "example": 0,
            "maximum": 100,
            "minimum": 0
          },
          "featured": {
            "type": "boolean",
            "description": "메인 노출 여부",
            "example": false
          },
          "campaignId": {
            "type": "string",
            "description": "캠페인 ID",
            "example": "spring-2026-gyeongbok",
            "maxLength": 100,
            "minLength": 0
          }
        },
        "required": [
          "featured",
          "latitude",
          "longitude",
          "maxSubmissions",
          "priority",
          "title"
        ]
      },
      "BaseResponseSystemMissionResponse": {
        "type": "object",
        "description": "API 공통 응답 래퍼",
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader",
            "description": "응답 헤더 (성공 여부, 상태 코드)"
          },
          "body": {
            "$ref": "#/components/schemas/SystemMissionResponse",
            "description": "응답 본문"
          }
        },
        "required": [
          "header"
        ]
      },
      "Gps": {
        "type": "object",
        "properties": {
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "altitude": {
            "type": "number",
            "format": "double"
          },
          "direction": {
            "type": "number",
            "format": "double"
          }
        },
        "required": [
          "latitude",
          "longitude"
        ]
      },
      "SystemMissionResponse": {
        "type": "object",
        "description": "시스템 미션 응답",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "gps": {
            "$ref": "#/components/schemas/Gps"
          },
          "address": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "OPEN",
              "CLOSED",
              "FULFILLED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "expiresAtEpochMilli": {
            "type": "integer",
            "format": "int64"
          },
          "maxSubmissions": {
            "type": "integer",
            "format": "int32"
          },
          "rewardDescription": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "format": "int32"
          },
          "featured": {
            "type": "boolean"
          },
          "campaignId": {
            "type": "string"
          },
          "createdAtEpochMilli": {
            "type": "integer",
            "format": "int64"
          },
          "updatedAtEpochMilli": {
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "createdAtEpochMilli",
          "gps",
          "id",
          "maxSubmissions",
          "status",
          "title",
          "updatedAtEpochMilli"
        ]
      },
      "ReviewSystemMissionSubmissionRequest": {
        "type": "object",
        "description": "검토 정보",
        "properties": {
          "accept": {
            "type": "boolean",
            "description": "채택 여부",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "검토 메시지",
            "example": "좋은 사진입니다!",
            "maxLength": 500,
            "minLength": 0
          }
        },
        "required": [
          "accept"
        ]
      },
      "Absent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PatchString"
          }
        ]
      },
      "Clear": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PatchString"
          }
        ]
      },
      "PatchString": {},
      "UpdateSystemMissionRequest": {
        "type": "object",
        "description": "수정할 정보",
        "properties": {
          "title": {
            "type": "string",
            "description": "미션 제목",
            "maxLength": 100,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "미션 설명",
            "maxLength": 2000,
            "minLength": 0
          },
          "expiresAtEpochMilli": {
            "type": "integer",
            "format": "int64",
            "description": "마감일시 (Epoch milliseconds)"
          },
          "maxSubmissions": {
            "type": "integer",
            "format": "int32",
            "description": "최대 제출 수",
            "maximum": 100,
            "minimum": 1
          },
          "rewardDescription": {
            "description": "보상 설명. null\u003d값 제거, 미포함\u003d변경 없음",
            "oneOf": [
              {
                "$ref": "#/components/schemas/Absent"
              },
              {
                "$ref": "#/components/schemas/Clear"
              },
              {
                "$ref": "#/components/schemas/Value"
              }
            ]
          },
          "priority": {
            "type": "integer",
            "format": "int32",
            "description": "우선순위",
            "maximum": 100,
            "minimum": 0
          },
          "featured": {
            "type": "boolean",
            "description": "메인 노출 여부"
          },
          "campaignId": {
            "description": "캠페인 ID. null\u003d값 제거, 미포함\u003d변경 없음",
            "oneOf": [
              {
                "$ref": "#/components/schemas/Absent"
              },
              {
                "$ref": "#/components/schemas/Clear"
              },
              {
                "$ref": "#/components/schemas/Value"
              }
            ]
          }
        },
        "required": [
          "campaignId",
          "rewardDescription"
        ]
      },
      "Value": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PatchString"
          },
          {
            "type": "object",
            "properties": {
              "value": {}
            }
          }
        ],
        "required": [
          "value"
        ]
      },
      "BaseResponseListUserDetailsResult": {
        "type": "object",
        "description": "API 공통 응답 래퍼",
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader",
            "description": "응답 헤더 (성공 여부, 상태 코드)"
          },
          "body": {
            "type": "array",
            "description": "응답 본문",
            "items": {
              "$ref": "#/components/schemas/UserDetailsResult"
            }
          }
        },
        "required": [
          "header"
        ]
      },
      "ProviderKey": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "GOOGLE",
              "FACEBOOK",
              "SYSTEM",
              "UNKNOWN"
            ]
          },
          "providerId": {
            "type": "string"
          },
          "userIdentifier": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "providerId",
          "userIdentifier"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "providerKey": {
            "$ref": "#/components/schemas/ProviderKey"
